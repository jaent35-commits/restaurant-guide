# 노션 동기화 설정 — 이 파일을 복사해 .env.local (개발) / .env.production (배포) 로 저장
# 값이 비어 있으면 동기화가 꺼지고 기존처럼 localStorage 로만 동작합니다.

# Cloudflare Worker 배포 후 발급되는 주소
VITE_API_BASE=https://rd-restaurant-notion-proxy.<계정서브도메인>.workers.dev

# (선택) 워커에 API_KEY 시크릿을 설정한 경우에만 입력
VITE_API_KEY=

# 네이버 클라우드 플랫폼 Maps — Client ID(ncpKeyId)
# NCP 콘솔 > Maps > 발급받은 Client ID. 콘솔의 "Web 서비스 URL"에 배포/개발 도메인 등록 필수.
VITE_NAVER_MAP_CLIENT_ID=
